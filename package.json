{
  "name": "synccorehub",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf {} + 2>/dev/null; true",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @synccorehub/database generate",
    "db:migrate": "pnpm --filter @synccorehub/database migrate",
    "db:studio": "pnpm --filter @synccorehub/database studio",
    "db:seed": "pnpm --filter @synccorehub/database seed"
  },
  "devDependencies": {
    "@synccorehub/typescript-config": "workspace:*",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.30.3"
}
